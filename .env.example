# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Coaching bookings (Calendly event URL — used on homepage and products)
NEXT_PUBLIC_CALENDLY_COACHING_URL=https://calendly.com/your-account/your-event

# Stripe checkout + webhooks. When payment links are unset, CTAs show "Setup pending".
# Set STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET to enable the /api/stripe/webhook handler.
# Each STRIPE_PAYMENT_LINK_* is the full buy.stripe.com/... URL from the Stripe dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_LINK_BUNDLE=
STRIPE_PAYMENT_LINK_EBOOK_BUNDLE=
STRIPE_PAYMENT_LINK_BUILT_DIFFERENT=
STRIPE_PAYMENT_LINK_MONTHLY_COACHING=
STRIPE_PAYMENT_LINK_TRANSFORMATION_3MO=
STRIPE_PAYMENT_LINK_SHE_REPLIED=
STRIPE_PAYMENT_LINK_FIRST_DATE=
STRIPE_PAYMENT_LINK_UNSHAKEABLE=
STRIPE_PAYMENT_LINK_PRESENCE=
STRIPE_PAYMENT_LINK_APPROACH=
STRIPE_PAYMENT_LINK_CONVERSATION=
STRIPE_PAYMENT_LINK_SWIPE_RIGHT=

# Auth + email (Phase 2)
AUTH_SECRET=
RESEND_API_KEY=
DATABASE_URL=

# Lead notifications. When unset, falls back to ADMIN_EMAILS. From-address must be
# a verified Resend sender. When RESEND_API_KEY is missing the lead is logged only.
LEAD_NOTIFICATION_EMAILS=
LEAD_NOTIFICATION_FROM=Short Kings Empire <leads@shortkingsempire.com>

# Admin console
ADMIN_EMAILS=axel@shortkingsempire.com,workwithcruz13@gmail.com
ADMIN_GATE_STRICT=0
